<Window x:Class="CsvViewer.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440"
        Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="26"
            Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="icon.png" Width="40" Height="40" Margin="0,0,12,0" />
                <StackPanel>
                    <TextBlock Text="CSV Viewer"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="正在启动，请稍候..."
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="ProgressTextBlock"
                           Text="正在初始化应用..."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="StartupProgressBar"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Margin="0,14,0,0" />
            </StackPanel>

            <TextBlock x:Name="PercentTextBlock"
                       Grid.Row="2"
                       Text="0%"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource TextMutedBrush}" />
        </Grid>
    </Border>
</Window>
