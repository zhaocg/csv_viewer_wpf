<Window x:Class="CsvViewer.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用说明"
        Width="760"
        Height="640"
        MinWidth="620"
        MinHeight="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="HelpHeadingTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>
        <Style x:Key="HelpBodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="21" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="22"
            Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
                <Button DockPanel.Dock="Right"
                        Content="关闭"
                        Width="78"
                        IsCancel="True"
                        Click="Close_Click" />
                <StackPanel>
                    <TextBlock Text="CSV Viewer 使用说明"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="用于快速查看本地和 SVN 远程 CSV/TXT 表格文件。"
                               Margin="0,6,16,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="1. 打开文件" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="点击顶部“打开文件”选择本地 CSV/TXT 文件，也可以拖拽文件到窗口中打开。支持多选文件并以多页签方式展示。" /></TextBlock>

                    <TextBlock Text="2. 文件夹与快速查找" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="左侧文件夹树显示当前本地目录或 SVN 远程目录。点击“查找”或按 Ctrl+P 可以打开快速查找窗口，输入文件名进行模糊搜索。" /></TextBlock>

                    <TextBlock Text="3. 搜索表格内容" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="按 Ctrl+F 聚焦右上角搜索框。输入关键词后按 Enter 或点击“搜索”，匹配结果会过滤显示并高亮命中的单元格。点击“清除”恢复完整表格。" /></TextBlock>

                    <TextBlock Text="4. 冻结窗口" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="选中一个单元格后点击“冻结到当前单元格”。冻结边界以该单元格左上角为准：冻结其上方行和左侧列。点击“取消冻结”可恢复。搜索时冻结行会保持显示。" /></TextBlock>

                    <TextBlock Text="5. 临时刷色" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="选中一个或多个单元格后点击“刷色”，会给这些单元格临时标记颜色。颜色只保存在当前页签内存中，关闭表格后自动清空，不会写入源文件。" /></TextBlock>

                    <TextBlock Text="6. 行列操作" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="点击列头可以选中整列，适合对整列执行刷色。双击行号会选中当前行，并根据该行内容自动调整所有列宽。Shift + 鼠标滚轮可以横向滚动表格。" /></TextBlock>

                    <TextBlock Text="7. SVN 模式" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="开启“SVN模式”后，软件会根据设置中的 SVN 路径模板和当前分支远程列目录。打开 SVN 文件时只按需读取单个文件，不会 checkout 整个目录。" /></TextBlock>

                    <TextBlock Text="8. SVN 日志" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="打开 SVN 文件后会显示“日志”按钮。点击可查看当前文件最近 100 条 SVN 日志，包括版本、作者、时间、提交说明和变更路径。点击“下 100 条”继续加载更早日志。" /></TextBlock>

                    <TextBlock Text="9. 全局设置" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="点击“设置”可以调整主题、编码、分隔符、是否隐藏列名行、SVN 路径模板和分支预设。设置会自动保存，并应用到已打开和后续打开的表格。" /></TextBlock>

                    <TextBlock Text="10. 主题" Style="{StaticResource HelpHeadingTextStyle}" />
                    <TextBlock Style="{StaticResource HelpBodyTextStyle}"><Run Text="支持亮色和暗色主题。暗色主题参考 VS Code 深色风格，适合长时间查看表格。" /></TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
