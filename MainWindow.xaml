<Window x:Class="CsvViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CsvViewer.ViewModels"
        xmlns:models="clr-namespace:CsvViewer.Models"
        mc:Ignorable="d"
        Title="CSV Viewer" Height="720" Width="1180"
        MinHeight="520" MinWidth="860"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="打开文件夹" Command="{Binding OpenFolderCommand}" InputGestureText="Ctrl+Shift+O" />
                <MenuItem Header="重新加载" Command="{Binding ReloadCommand}" />
                <Separator />
                <MenuItem Header="退出" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="编辑">
                <MenuItem Header="复制选中内容" Click="CopySelected_Click" InputGestureText="Ctrl+C" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Padding="10" Background="#F5F7FA" BorderBrush="#D8DEE9" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开文件" Command="{Binding OpenFileCommand}" Padding="14,6" Margin="0,0,8,0" />
                    <TextBlock Text="编码" VerticalAlignment="Center" Margin="8,0,4,0" />
                    <ComboBox Width="90" ItemsSource="{Binding EncodingOptions}" SelectedItem="{Binding SelectedEncoding}" />
                    <TextBlock Text="分隔符" VerticalAlignment="Center" Margin="12,0,4,0" />
                    <ComboBox Width="120" ItemsSource="{Binding DelimiterOptions}" SelectedItem="{Binding SelectedDelimiter}" />
                    <Button Content="重新加载" Command="{Binding ReloadCommand}" Padding="12,6" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox Width="260" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                    <Button Content="搜索" Command="{Binding ApplySearchCommand}" Padding="12,6" Margin="8,0,0,0" />
                    <Button Content="清除" Command="{Binding ClearSearchCommand}" Padding="12,6" Margin="6,0,0,0" />
                    <Button Content="复制" Click="CopySelected_Click" Padding="12,6" Margin="14,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="180" MaxWidth="380" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#D8DEE9" BorderThickness="0,0,0,0" Background="#FAFBFC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="10,8" Background="#EEF1F5" BorderBrush="#D8DEE9" BorderThickness="0,0,0,1">
                        <TextBlock Text="文件夹" FontWeight="SemiBold" FontSize="13" />
                    </Border>

                    <TreeView x:Name="FolderTreeView"
                              Grid.Row="1"
                              ItemsSource="{Binding FolderTreeRoot}"
                              TreeViewItem.Expanded="FolderTreeView_ItemExpanded"
                              TreeViewItem.Selected="FolderTreeView_ItemSelected"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="4,4">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="{Binding Name}" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False" />

            <Grid Grid.Column="2">
                <DataGrid x:Name="CsvDataGrid"
                          ItemsSource="{Binding TableView}"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="CellOrRowHeader"
                          GridLinesVisibility="All"
                          HeadersVisibility="All"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          LoadingRow="CsvDataGrid_LoadingRow" />

                <Border Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="260" Height="8" IsIndeterminate="True" />
                        <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding StatusText}" />
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="文件: "/><Run Text="{Binding FileName, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="大小: "/><Run Text="{Binding FileSizeText, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="行: "/><Run Text="{Binding RowCountText, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="列: "/><Run Text="{Binding ColumnCountText, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="编码: "/><Run Text="{Binding EncodingName, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="分隔符: "/><Run Text="{Binding DelimiterName, Mode=OneWay}" /></TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
