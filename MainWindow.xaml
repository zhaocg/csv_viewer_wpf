<Window x:Class="CsvViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CsvViewer.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CsvViewer.ViewModels"
        xmlns:models="clr-namespace:CsvViewer.Models"
        mc:Ignorable="d"
        Title="CSV Viewer" Height="720" Width="1180"
        MinHeight="520" MinWidth="860"
        AllowDrop="True"
        Loaded="Window_Loaded"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:SearchHighlightBrushConverter x:Key="SearchHighlightBrushConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="打开文件夹" Command="{Binding OpenFolderCommand}" InputGestureText="Ctrl+Shift+O" />
                <MenuItem Header="重新加载" Command="{Binding ReloadCommand}" />
                <Separator />
                <MenuItem Header="退出" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="编辑">
                <MenuItem Header="复制选中内容" Click="CopySelected_Click" InputGestureText="Ctrl+C" />
            </MenuItem>
            <MenuItem Header="视图">
                <MenuItem Header="冻结到当前单元格" Click="FreezeToCurrentCell_Click" />
                <MenuItem Header="取消冻结" Click="ClearFreeze_Click" Visibility="{Binding HasFrozenCells, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Separator />
                <MenuItem Header="设置..." Click="Settings_Click" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Padding="10" Background="#F5F7FA" BorderBrush="#D8DEE9" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开文件" Command="{Binding OpenFileCommand}" Padding="14,6" Margin="0,0,8,0" />
                    <Button Content="重新加载" Command="{Binding ReloadCommand}" Padding="12,6" Margin="8,0,0,0" />
                    <Button Content="冻结到当前单元格" Click="FreezeToCurrentCell_Click" Padding="12,6" Margin="14,0,0,0" />
                    <Button Content="取消冻结" Click="ClearFreeze_Click" Padding="12,6" Margin="6,0,0,0" Visibility="{Binding HasFrozenCells, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="设置" Click="Settings_Click" Padding="12,6" Margin="6,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox Width="260" Text="{Binding SelectedDocument.SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ApplySearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="搜索" Command="{Binding ApplySearchCommand}" Padding="12,6" Margin="8,0,0,0" />
                    <Button Content="清除" Command="{Binding ClearSearchCommand}" Padding="12,6" Margin="6,0,0,0" />
                    <Button Content="复制" Click="CopySelected_Click" Padding="12,6" Margin="14,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="180" MaxWidth="380" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#D8DEE9" BorderThickness="0,0,0,0" Background="#FAFBFC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="10,8" Background="#EEF1F5" BorderBrush="#D8DEE9" BorderThickness="0,0,0,1">
                        <TextBlock Text="文件夹" FontWeight="SemiBold" FontSize="13" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="8,8,8,4">
                        <TextBlock Text="搜索文件" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                        <TextBox Text="{Binding FolderSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" />
                        <ListBox x:Name="FolderSearchResultsListBox"
                                 ItemsSource="{Binding FolderSearchResults}"
                                 SelectionChanged="FileListBox_SelectionChanged"
                                 MaxHeight="150"
                                 Margin="0,6,0,0"
                                 BorderBrush="#D8DEE9">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFolderSearchText}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel ToolTip="{Binding FullPath}">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FullPath}" Foreground="#667085" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <Expander Grid.Row="2" Header="最近打开" IsExpanded="True" Margin="8,2,8,6">
                        <ListBox x:Name="RecentFilesListBox"
                                 ItemsSource="{Binding RecentFiles}"
                                 SelectionChanged="FileListBox_SelectionChanged"
                                 MaxHeight="130"
                                 BorderBrush="#D8DEE9">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel ToolTip="{Binding FullPath}">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FullPath}" Foreground="#667085" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>

                    <TreeView x:Name="FolderTreeView"
                              Grid.Row="3"
                              ItemsSource="{Binding FolderTreeRoot}"
                              TreeViewItem.Expanded="FolderTreeView_ItemExpanded"
                              TreeViewItem.Selected="FolderTreeView_ItemSelected"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="4,4">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="{Binding Name}" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False" />

            <Grid Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="DocumentTabControl"
                                Grid.Row="0"
                                ItemsSource="{Binding Documents}"
                                SelectedItem="{Binding SelectedDocument}"
                                SelectionChanged="DocumentTabControl_SelectionChanged"
                                Margin="0,0,0,2">
                        <TabControl.Style>
                            <Style TargetType="TabControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Documents.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Style>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True" MinWidth="120">
                                    <Button DockPanel.Dock="Right"
                                            Content="×"
                                            Command="{Binding DataContext.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,0"
                                            Margin="8,0,0,0"
                                            BorderThickness="0"
                                            Background="Transparent" />
                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid Height="0" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="FrozenRowsDataGrid"
                                  Grid.Row="0"
                                  ItemsSource="{Binding SelectedDocument.FrozenTableView}"
                                  Visibility="{Binding SelectedDocument.HasFrozenRows, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="True"
                                  CanUserSortColumns="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  GridLinesVisibility="All"
                                  HeadersVisibility="Row"
                                  RowHeaderWidth="60"
                                  MaxHeight="240"
                                  EnableRowVirtualization="False"
                                  EnableColumnVirtualization="True"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.ScrollChanged="FrozenRowsDataGrid_ScrollChanged"
                                  AutoGeneratedColumns="FrozenRowsDataGrid_AutoGeneratedColumns"
                                  LoadingRow="FrozenRowsDataGrid_LoadingRow" />

                        <DataGrid x:Name="CsvDataGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding SelectedDocument.ScrollableTableView}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="True"
                                  CanUserSortColumns="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  GridLinesVisibility="All"
                                  RowHeaderWidth="60"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.ScrollChanged="CsvDataGrid_ScrollChanged"
                                  AutoGeneratedColumns="CsvDataGrid_AutoGeneratedColumns"
                                  LoadingRow="CsvDataGrid_LoadingRow">
                            <DataGrid.Style>
                                <Style TargetType="DataGrid">
                                    <Setter Property="HeadersVisibility" Value="All" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HideColumnHeaders}" Value="True">
                                            <Setter Property="HeadersVisibility" Value="Row" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Style>
                        </DataGrid>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="请打开或拖拽 CSV 文件。"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#6B7280"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Border Background="#80FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="260" Height="8" IsIndeterminate="True" />
                        <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding StatusText}" />
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="文件: "/><Run Text="{Binding SelectedDocument.FileName, Mode=OneWay, TargetNullValue=未打开文件}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="大小: "/><Run Text="{Binding SelectedDocument.FileSizeText, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="行: "/><Run Text="{Binding SelectedDocument.RowCountText, Mode=OneWay, TargetNullValue=0}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="列: "/><Run Text="{Binding SelectedDocument.ColumnCountText, Mode=OneWay, TargetNullValue=0}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="编码: "/><Run Text="{Binding SelectedDocument.EncodingName, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="分隔符: "/><Run Text="{Binding SelectedDocument.DelimiterName, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="FreezeStatusText" Text="冻结: 无" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
