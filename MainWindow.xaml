<Window x:Class="CsvViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CsvViewer.Converters"
        xmlns:local="clr-namespace:CsvViewer"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CsvViewer.ViewModels"
        xmlns:models="clr-namespace:CsvViewer.Models"
        mc:Ignorable="d"
        Title="CSV Viewer" Height="720" Width="1180"
        WindowState="Maximized"
        MinHeight="520" MinWidth="860"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:SearchHighlightBrushConverter x:Key="SearchHighlightBrushConverter" />
        <converters:SelectedDocumentVisibilityConverter x:Key="SelectedDocumentVisibilityConverter" />

        <Style x:Key="DocumentTabControlStyle" TargetType="{x:Type TabControl}" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Background" Value="{DynamicResource DocumentTabBarBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="0" />
                            </Grid.RowDefinitions>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1" />
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocumentTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource DocumentTabTextBrush}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="{DynamicResource DocumentTabBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid MinHeight="34">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0,0,1,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Border x:Name="TopAccent"
                                    Height="1"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DocumentTabSelectedTextBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DocumentTabHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="10" />
                                <Setter Property="Foreground" Value="{DynamicResource DocumentTabSelectedTextBrush}" />
                                <Setter Property="Background" Value="{DynamicResource DocumentTabSelectedBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                                <Setter TargetName="TopAccent" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocumentTabCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3D41" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#45494E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0"
              Margin="8,2"
              Background="{DynamicResource AppBackgroundBrush}"
              Foreground="{DynamicResource MenuTextBrush}">
            <MenuItem Header="文件">
                <MenuItem Header="打开" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="打开文件夹" Command="{Binding OpenFolderCommand}" InputGestureText="Ctrl+Shift+O" />
                <MenuItem Header="重新加载" Command="{Binding ReloadCommand}" />
                <Separator />
                <MenuItem Header="退出" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="视图">
                <MenuItem Header="冻结到当前单元格" Click="FreezeToCurrentCell_Click" />
                <MenuItem Header="取消冻结" Click="ClearFreeze_Click" Visibility="{Binding HasFrozenCells, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="全局设置" Click="Settings_Click" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="使用说明" Click="Help_Click" />
                <MenuItem Header="关于" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Padding="14,12" Background="{DynamicResource TopBarBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="打开文件" Command="{Binding OpenFileCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="14,7" Margin="0,0,8,0" />
                    <ToggleButton Content="SVN模式" IsChecked="{Binding IsSvnMode, Mode=OneWay}" Checked="SvnModeToggle_Changed" Unchecked="SvnModeToggle_Changed" Padding="12,6" Margin="0,0,8,0" />
                    <TextBlock Text="分支" Foreground="#DDE7F6" VerticalAlignment="Center" Margin="4,0,4,0" Visibility="{Binding IsSvnMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ComboBox Width="150" ItemsSource="{Binding SvnBranches}" SelectedItem="{Binding SelectedSvnBranch, Mode=OneWay}" SelectionChanged="SvnBranchComboBox_SelectionChanged" Visibility="{Binding IsSvnMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="重新加载" Command="{Binding ReloadCommand}" Padding="12,6" Margin="8,0,0,0" />
                    <Button Content="更新" Command="{Binding UpdateRemoteDocumentCommand}" Padding="12,6" Margin="6,0,0,0" Visibility="{Binding IsRemoteDocument, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="日志" Click="SvnLog_Click" Padding="12,6" Margin="6,0,0,0" Visibility="{Binding IsRemoteDocument, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="冻结到当前单元格" Click="FreezeToCurrentCell_Click" Padding="12,6" Margin="14,0,0,0" />
                    <Button Content="取消冻结" Click="ClearFreeze_Click" Padding="12,6" Margin="6,0,0,0" Visibility="{Binding HasFrozenCells, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="刷色" Click="PaintSelectedCells_Click" Padding="12,6" Margin="6,0,0,0" ToolTip="给选中的单元格临时刷色" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox x:Name="SearchTextBox"
                             Width="290"
                             Text="{Binding SelectedDocument.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             ToolTip="搜索当前表格 (Ctrl+F)">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ApplySearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <ToggleButton Content="Aa"
                                  IsChecked="{Binding SelectedDocument.IsSearchCaseSensitive, Mode=TwoWay}"
                                  Style="{StaticResource SearchOptionToggleStyle}"
                                  ToolTip="大小写敏感" />
                    <ToggleButton Content="ab"
                                  IsChecked="{Binding SelectedDocument.IsSearchWholeWord, Mode=TwoWay}"
                                  Style="{StaticResource SearchOptionToggleStyle}"
                                  ToolTip="全词匹配" />
                    <ToggleButton Content=".*"
                                  IsChecked="{Binding SelectedDocument.IsSearchRegex, Mode=TwoWay}"
                                  Style="{StaticResource SearchOptionToggleStyle}"
                                  ToolTip="正则表达式" />
                    <Button Content="搜索" Command="{Binding ApplySearchCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Margin="8,0,0,0" />
                    <Button Content="清除" Command="{Binding ClearSearchCommand}" Padding="12,6" Margin="6,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180" MaxWidth="380" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="12,12,0,12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="14,12" Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="16,16,0,0">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="查找"
                                    Click="QuickOpen_Click"
                                    Padding="10,4"
                                    MinHeight="0"
                                    ToolTip="快速查找文件 (Ctrl+P)" />
                            <TextBlock Text="文件夹"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </DockPanel>
                    </Border>

                    <Expander Grid.Row="1" Header="最近打开" IsExpanded="True" Margin="12,12,12,8" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="4">
                            <ListBox x:Name="RecentFilesListBox"
                                     ItemsSource="{Binding RecentFiles}"
                                     SelectionChanged="FileListBox_SelectionChanged"
                                     MaxHeight="130"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel ToolTip="{Binding FullPath}">
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FullPath}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Expander>

                    <TreeView x:Name="FolderTreeView"
                              Grid.Row="2"
                              ItemsSource="{Binding FolderTreeRoot}"
                              TreeViewItem.Expanded="FolderTreeView_ItemExpanded"
                              TreeViewItem.Selected="FolderTreeView_ItemSelected"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="10,6"
                              ClipToBounds="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Foreground="{DynamicResource TextPrimaryBrush}">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2563EB" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2563EB" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF" />
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <Border Grid.Row="2"
                            Margin="12"
                            Padding="12"
                            Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="10"
                            VerticalAlignment="Top"
                            Visibility="{Binding HasFolderTreeMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding FolderTreeMessage}"
                                   Foreground="#991B1B"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False" />

            <Border Grid.Column="2"
                    Margin="0,12,12,12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="DocumentTabControl"
                                 Grid.Row="0"
                                 ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument}"
                                 SelectionChanged="DocumentTabControl_SelectionChanged"
                                 Margin="12,12,12,0">
                        <TabControl.Style>
                            <Style TargetType="TabControl" BasedOn="{StaticResource DocumentTabControlStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Documents.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Style>
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource DocumentTabItemStyle}">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="DocumentTabItem_PreviewMouseRightButtonDown" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu MinWidth="140">
                                            <MenuItem Header="关闭"
                                                      Style="{StaticResource ContextMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.Tag.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="关闭其他"
                                                      Style="{StaticResource ContextMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.Tag.CloseOtherDocumentsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="关闭右侧"
                                                      Style="{StaticResource ContextMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.Tag.CloseDocumentsToRightCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator Style="{StaticResource ContextMenuSeparatorStyle}" />
                                            <MenuItem Header="关闭全部"
                                                      Style="{StaticResource ContextMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.Tag.CloseAllDocumentsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinWidth="124" Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Width="14"
                                          Height="14"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center">
                                        <Border Width="10"
                                                Height="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                                BorderThickness="1" />
                                        <Rectangle Width="4"
                                                   Height="4"
                                                   Margin="4,3,0,0"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               Text="SVN"
                                               Foreground="#67E8F9"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FileName}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />

                                    <Button Grid.Column="3"
                                            Content="×"
                                            Command="{Binding DataContext.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource DocumentTabCloseButtonStyle}" />
                                </Grid>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid Height="0" />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <ItemsControl x:Name="DocumentContentItemsControl"
                                  Grid.Row="1"
                                  ItemsSource="{Binding Documents}"
                                  Margin="12,0,12,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:CsvDocumentGrid>
                                    <local:CsvDocumentGrid.Visibility>
                                        <MultiBinding Converter="{StaticResource SelectedDocumentVisibilityConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.SelectedDocument" RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </local:CsvDocumentGrid.Visibility>
                                </local:CsvDocumentGrid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Row="1"
                               Text="请打开或拖拽 CSV 文件。"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="17">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                <Border Grid.RowSpan="2" Background="{DynamicResource LoadingOverlayBrush}" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="260" Height="8" IsIndeterminate="True" />
                        <TextBlock Text="{Binding StatusText}" Margin="0,12,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding StatusText}" />
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="文件: "/><Run Text="{Binding SelectedDocument.FileName, Mode=OneWay, TargetNullValue=未打开文件}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="大小: "/><Run Text="{Binding SelectedDocument.FileSizeText, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="行: "/><Run Text="{Binding SelectedDocument.RowCountText, Mode=OneWay, TargetNullValue=0}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="列: "/><Run Text="{Binding SelectedDocument.ColumnCountText, Mode=OneWay, TargetNullValue=0}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="编码: "/><Run Text="{Binding SelectedDocument.EncodingName, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock><Run Text="分隔符: "/><Run Text="{Binding SelectedDocument.DelimiterName, Mode=OneWay, TargetNullValue=-}" /></TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding FreezeStatusText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
