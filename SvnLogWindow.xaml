<Window x:Class="CsvViewer.SvnLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="920"
        Height="640"
        MinWidth="720"
        MinHeight="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="18"
            Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="关闭"
                        Width="78"
                        IsCancel="True"
                        Click="Close_Click" />
                <StackPanel>
                     <TextBlock Text="SVN 日志"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}" />
                     <TextBlock Text="{Binding FileUrl}"
                                Margin="0,6,16,0"
                                Foreground="{DynamicResource TextMutedBrush}"
                                TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Text="{Binding StatusText}"
                       Margin="0,14,0,10"
                       Foreground="{DynamicResource TextSecondaryBrush}" />

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Entries}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="False"
                      RowHeight="NaN"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="MinHeight" Value="34" />
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="版本" Binding="{Binding RevisionText}" Width="90" />
                    <DataGridTextColumn Header="作者" Binding="{Binding Author}" Width="120" />
                    <DataGridTextColumn Header="时间" Binding="{Binding DateText}" Width="160" />
                    <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="Padding" Value="4,2" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="变更路径" Binding="{Binding ChangedPathsText}" Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="Padding" Value="4,2" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,14,0,0">
                <Button DockPanel.Dock="Right"
                        Content="下 100 条"
                        Width="100"
                        Click="LoadMore_Click"
                        IsEnabled="{Binding CanLoadMore}" />
                <ProgressBar Width="180"
                             Height="8"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
