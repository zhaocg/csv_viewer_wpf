<UserControl x:Class="CsvViewer.CsvDocumentGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CsvViewer.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:SearchHighlightBrushConverter x:Key="SearchHighlightBrushConverter" />
        <converters:SearchHighlightForegroundConverter x:Key="SearchHighlightForegroundConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="FrozenRowsDataGrid"
                  Grid.Row="0"
                  ItemsSource="{Binding FrozenTableView}"
                  Visibility="{Binding HasFrozenRows, Converter={StaticResource BooleanToVisibilityConverter}}"
                  IsReadOnly="True"
                  AutoGenerateColumns="True"
                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  SelectedCellsChanged="FrozenRowsDataGrid_SelectedCellsChanged"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  GridLinesVisibility="All"
                  Margin="0,0,0,6"
                  RowHeaderWidth="60"
                  MaxHeight="240"
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="True"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="CsvDataGrid_PreviewMouseWheel"
                  ScrollViewer.ScrollChanged="FrozenRowsDataGrid_ScrollChanged"
                  AutoGeneratedColumns="FrozenRowsDataGrid_AutoGeneratedColumns"
                  LoadingRow="FrozenRowsDataGrid_LoadingRow">
            <DataGrid.Style>
                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                    <Setter Property="HeadersVisibility" Value="All" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HideColumnHeaders, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="HeadersVisibility" Value="Row" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>

        <DataGrid x:Name="CsvDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding ScrollableTableView}"
                  IsReadOnly="True"
                  AutoGenerateColumns="True"
                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  SelectedCellsChanged="CsvDataGrid_SelectedCellsChanged"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  GridLinesVisibility="All"
                  RowHeaderWidth="60"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  PreviewMouseWheel="CsvDataGrid_PreviewMouseWheel"
                  ScrollViewer.ScrollChanged="CsvDataGrid_ScrollChanged"
                  AutoGeneratedColumns="CsvDataGrid_AutoGeneratedColumns"
                  LoadingRow="CsvDataGrid_LoadingRow">
            <DataGrid.Style>
                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                    <Setter Property="HeadersVisibility" Value="All" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HideColumnHeaders, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="HeadersVisibility" Value="Row" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasFrozenRows}" Value="True">
                            <Setter Property="HeadersVisibility" Value="Row" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>

        <Border Grid.RowSpan="2"
                Margin="18"
                Padding="18"
                Background="#FEF2F2"
                BorderBrush="#FCA5A5"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="520"
                Visibility="{Binding HasDisplayMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding DisplayMessage}"
                       Foreground="#991B1B"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
