<UserControl x:Class="CsvViewer.CsvDocumentGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CsvViewer.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:SearchHighlightBrushConverter x:Key="SearchHighlightBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="FrozenRowsDataGrid"
                  Grid.Row="0"
                  ItemsSource="{Binding FrozenTableView}"
                  Visibility="{Binding HasFrozenRows, Converter={StaticResource BooleanToVisibilityConverter}}"
                  IsReadOnly="True"
                  AutoGenerateColumns="True"
                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  GridLinesVisibility="All"
                  HeadersVisibility="Row"
                  RowHeaderWidth="60"
                  MaxHeight="240"
                  EnableRowVirtualization="False"
                  EnableColumnVirtualization="True"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  PreviewMouseWheel="CsvDataGrid_PreviewMouseWheel"
                  ScrollViewer.ScrollChanged="FrozenRowsDataGrid_ScrollChanged"
                  AutoGeneratedColumns="FrozenRowsDataGrid_AutoGeneratedColumns"
                  LoadingRow="FrozenRowsDataGrid_LoadingRow" />

        <DataGrid x:Name="CsvDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding ScrollableTableView}"
                  IsReadOnly="True"
                  AutoGenerateColumns="True"
                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  GridLinesVisibility="All"
                  RowHeaderWidth="60"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  PreviewMouseWheel="CsvDataGrid_PreviewMouseWheel"
                  ScrollViewer.ScrollChanged="CsvDataGrid_ScrollChanged"
                  AutoGeneratedColumns="CsvDataGrid_AutoGeneratedColumns"
                  LoadingRow="CsvDataGrid_LoadingRow">
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Setter Property="HeadersVisibility" Value="All" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.HideColumnHeaders, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="HeadersVisibility" Value="Row" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>
    </Grid>
</UserControl>
